{
  "expo": {
    "name": "WeatherBeacon",
    "slug": "pingweather",
    "scheme": "pingweather",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A5F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.truthcenteredtech.pingweather",
      "googleServicesFile": "./GoogleService-Info.plist",
      "buildNumber": "1",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "NSLocationWhenInUseUsageDescription": "WeatherBeacon uses your location to monitor weather conditions at sites you care about and alert you when they match your rules.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "WeatherBeacon uses your location to monitor weather conditions at sites you care about and alert you when they match your rules.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "package": "com.truthcenteredtech.pingweather",
      "versionCode": 7,
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E3A5F"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/withAdiRegistration",
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1E3A5F",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "WeatherBeacon uses your location to monitor weather conditions at sites you care about and alert you when they match your rules.",
          "locationWhenInUsePermission": "WeatherBeacon uses your location to show weather for places near you.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      "expo-build-properties",
      "@rnmapbox/maps"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6456b66e-6e5a-4881-984f-20e2f3b477f4"
      },
      "revenueCatAndroidApiKey": "goog_XykDmtoZwUNDfBgswNJaIkDLjNC",
      "revenueCatIosApiKey": "appl_DeIxqgxLsLaIeIrHALmieFljZFS"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6456b66e-6e5a-4881-984f-20e2f3b477f4",
      "checkAutomatically": "NEVER"
    },
    "owner": "jimmy.thorne.10"
  }
}
