{
  "expo": {
    "name": "PingWeather",
    "slug": "pingweather",
    "scheme": "pingweather",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A5F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.truthcenteredtech.pingweather"
    },
    "android": {
      "package": "com.truthcenteredtech.pingweather",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E3A5F"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1E3A5F",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "PingWeather uses your location to monitor weather conditions at sites you care about and alert you when they match your rules.",
          "locationWhenInUsePermission": "PingWeather uses your location to show weather for places near you.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      "expo-build-properties"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6456b66e-6e5a-4881-984f-20e2f3b477f4"
      },
      "revenueCatApiKey": ""
    },
    "owner": "jimmy.thorne.10"
  }
}
